# Adzuna API - https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# Jooble API - https://jooble.org/api/about
JOOBLE_KEY=your_jooble_key_here

# CallMeBot WhatsApp - https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Send "I allow callmebot to send me messages" to +34 644 51 95 23 on WhatsApp first
CALLMEBOT_PHONE=917276385283
CALLMEBOT_API_KEY=your_callmebot_key_here

# Telegram Bot (fallback notifier) - https://core.telegram.org/bots#botfather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: proxy for scraping
# HTTP_PROXY=http://user:pass@host:port
